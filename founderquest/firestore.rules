rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // Acciones logueadas. La lista blanca de actionIds incluye sales + jobhunt.
    // El XP máximo subió a 250 (igual que antes, OFFER_RECEIVED entra en rango).
    match /users/{uid}/actions/{actionId} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['actionId', 'xp', 'label'])
        && request.resource.data.xp is int
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 250
        && request.resource.data.actionId in [
            // Sales
            'LINKEDIN_MSG', 'RECEIVE_NO', 'POSITIVE_REPLY',
            'MEET_15', 'PAIN_FOUND', 'PITCH_MENSSO', 'CLOSE',
            // Jobhunt
            'APPLY_JOB', 'CV_FEEDBACK', 'PUBLISH_LI',
            'REJECTION_JOB', 'CONNECT_LEADER', 'TECH_INTERVIEW',
            'OFFER_RECEIVED'
          ];

      allow update: if false;
      allow delete: if isOwner(uid);
    }

    // Contactos. Stages combinados de ambos tracks (la app filtra
    // visualmente por track, pero la regla acepta cualquier stage válido
    // de cualquier track para no complicar el modelo).
    match /users/{uid}/contacts/{contactId} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.stage in [
            // Sales
            'prospecto', 'contactado', 'conversacion', 'validado', 'cierre',
            // Jobhunt (prospecto y contactado se reusan)
            'entrevista', 'oferta', 'rechazado'
          ]
        && request.resource.data.track in ['sales', 'jobhunt'];

      allow update: if isOwner(uid)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.stage in [
            'prospecto', 'contactado', 'conversacion', 'validado', 'cierre',
            'entrevista', 'oferta', 'rechazado'
          ]
        && request.resource.data.track in ['sales', 'jobhunt'];

      allow delete: if isOwner(uid);
    }
  }
}
