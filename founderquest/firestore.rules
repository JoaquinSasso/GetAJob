rules_version = '2';

// FounderQuest · Firestore Security Rules
// Modelo de datos:
//   users/{uid}/actions/{actionId}   ← log de acciones (XP)
//   users/{uid}/contacts/{contactId} ← pipeline de aliados
//
// Regla general: un usuario autenticado SOLO puede leer y escribir
// dentro de su propio subárbol users/{uid}/... Nadie más.

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: el usuario está autenticado y es dueño del recurso
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Bloqueo por defecto: todo lo demás denegado
    match /{document=**} {
      allow read, write: if false;
    }

    // Subcolección de acciones logueadas
    match /users/{uid}/actions/{actionId} {
      allow read: if isOwner(uid);

      // Al crear, validamos que el payload sea consistente y
      // que el usuario no pueda asignarse XP arbitrario (ver lista blanca de XP)
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['actionId', 'xp', 'label'])
        && request.resource.data.xp is int
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 250
        && request.resource.data.actionId in [
            'LINKEDIN_MSG', 'RECEIVE_NO', 'POSITIVE_REPLY',
            'MEET_15', 'PAIN_FOUND', 'PITCH_MENSSO', 'CLOSE'
          ];

      // Las acciones son append-only: no permitimos editarlas,
      // así la bitácora es un registro honesto del camino.
      allow update: if false;
      allow delete: if isOwner(uid);
    }

    // Subcolección de contactos (aliados del pipeline)
    match /users/{uid}/contacts/{contactId} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.stage in [
            'prospecto', 'contactado', 'conversacion', 'validado', 'cierre'
          ];

      allow update: if isOwner(uid)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.stage in [
            'prospecto', 'contactado', 'conversacion', 'validado', 'cierre'
          ];

      allow delete: if isOwner(uid);
    }
  }
}
